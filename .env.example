# Firebase Admin (server-side). Tanpa ini, app pakai in-memory store (dev/demo).
#
# Ambil dari: Firebase Console > Project Settings > Service accounts >
# "Generate new private key" → file JSON. Tempel SELURUH isi JSON itu (minified,
# satu baris) di antara tanda kutip tunggal.
FIREBASE_SERVICE_ACCOUNT='{"type":"service_account","project_id":"dpr-bmn", ... }'

# WhatsApp Mekari Qontak (step 4 — belum dipakai)
# QONTAK_TOKEN=
# QONTAK_CHANNEL_ID=
# QONTAK_TEMPLATE_ID=

# Password admin (step 3 — belum dipakai)
# ADMIN_PASSWORD=
